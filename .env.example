# ── Clinical Copilot Engine — Environment Configuration ─────────────
# Copy this file to .env and fill in your values.

# ── Application ─────────────────────────────────────────────────────
APP_NAME="Clinical Copilot Engine"
APP_VERSION="0.1.0"
DEBUG=true
LOG_LEVEL=INFO

# ── Server ──────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ── CORS ────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Rate Limiting ───────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=300

# ── Ollama / BioMistral ────────────────────────────────────────────
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=cniongolo/biomistral
OLLAMA_TIMEOUT_SECONDS=30.0
OLLAMA_STREAM_TIMEOUT_SECONDS=60.0
OLLAMA_MAX_TOKENS=60
OLLAMA_TEMPERATURE=0.3
OLLAMA_TOP_P=0.9
OLLAMA_REPEAT_PENALTY=1.1

# ── Autocomplete Tuning ────────────────────────────────────────────
MAX_SUGGESTION_LENGTH=80
MIN_PREFIX_LENGTH=2
MAX_TRIE_RESULTS=10
DEBOUNCE_MS=150

# ── UMLS / Data Download ───────────────────────────────────────────
# Register free at https://uts.nlm.nih.gov — required for Layer 2 live lookup
UMLS_API_KEY=
# LOINC credentials (free registration at https://loinc.org)
LOINC_USERNAME=
LOINC_PASSWORD=