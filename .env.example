# ── Clinical Copilot Engine — Environment Configuration ─────────────
# Copy this file to .env and fill in your values.

# ── Application ─────────────────────────────────────────────────────
APP_NAME="Clinical Copilot Engine"
APP_VERSION="0.1.0"
DEBUG=true
LOG_LEVEL=INFO

# ── Server ──────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ── CORS ────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Rate Limiting ───────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=300

# ── vLLM / BioMistral ──────────────────────────────────────────────
VLLM_BASE_URL=http://localhost:8001/v1
VLLM_MODEL_NAME=BioMistral/BioMistral-7B-GPTQ
VLLM_TIMEOUT_SECONDS=10.0
VLLM_MAX_TOKENS=60
VLLM_TEMPERATURE=0.3
VLLM_TOP_P=0.9

# ── Autocomplete Tuning ────────────────────────────────────────────
MAX_SUGGESTION_LENGTH=80
MIN_PREFIX_LENGTH=2
MAX_TRIE_RESULTS=10
DEBOUNCE_MS=150

# ── UMLS / Data Download ───────────────────────────────────────────
# Get your UMLS API key at: https://uts.nlm.nih.gov/uts/profile
UMLS_API_KEY=
# LOINC credentials (free registration at https://loinc.org)
LOINC_USERNAME=
LOINC_PASSWORD=